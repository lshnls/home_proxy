# Generated by iptables-save on Thu Aug 10 14:31:09 2023
*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
-A INPUT -i lo -j ACCEPT

-A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT

# Allow HTTP/HTTPS
-A INPUT -p tcp -m multiport --dports 22,80,443 -j ACCEPT

# Allow DNS
-A INPUT -p udp -m multiport --dports 53,123 -j ACCEPT

# Allow local traffic
-A FORWARD -i home_proxy_proxy_network -o eth0 -m state --state RELATED,ESTABLISHED -j ACCEPT
-A FORWARD -s 172.17.0.0/16 -o home_proxy_proxy_network -j ACCEPT
-A FORWARD -s 172.17.0.0/16 -o eth0 -j DROP

# Allow outgoing traffic
-A OUTPUT -o lo -j RETURN
-A OUTPUT -m state --state NEW -j ACCEPT

# Allow HTTP/HTTPS
-A OUTPUT -p tcp -m multiport --sports 80,443 --dports 80,443 -j ACCEPT
-A OUTPUT -p udp -m multiport --dports 53,123 -j ACCEPT