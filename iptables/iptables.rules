# Правила iptables для прозрачного проксирования клиентов из LAN
# Сеть клиентов: 192.168.1.0/24
# Squid в Docker слушает опубликованные порты хоста 8081/8082

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]

# Не трогаем loopback и локальные/служебные назначения
-A PREROUTING -i lo -j RETURN
-A PREROUTING -s 192.168.1.0/24 -d 192.168.1.0/24 -j RETURN
-A PREROUTING -s 192.168.1.0/24 -d 10.0.0.0/8 -j RETURN
-A PREROUTING -s 192.168.1.0/24 -d 172.16.0.0/12 -j RETURN
-A PREROUTING -s 192.168.1.0/24 -d 192.168.0.0/16 -j RETURN
-A PREROUTING -s 192.168.1.0/24 -d 127.0.0.0/8 -j RETURN

# Прозрачное перенаправление HTTP/HTTPS в Squid
-A PREROUTING -s 192.168.1.0/24 -p tcp --dport 80 -j REDIRECT --to-ports 8081
-A PREROUTING -s 192.168.1.0/24 -p tcp --dport 443 -j REDIRECT --to-ports 8082
COMMIT

*filter
:INPUT ACCEPT [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Разрешаем уже установленные соединения
-A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# Разрешаем клиентам LAN выход через хост
-A FORWARD -s 192.168.1.0/24 -j ACCEPT

# Блокируем QUIC, чтобы HTTPS шел через TCP/443 (и попадал в прокси)
-A FORWARD -s 192.168.1.0/24 -p udp --dport 443 -j DROP
COMMIT
